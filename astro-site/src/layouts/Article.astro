---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const { title, description, pubDate, author, image, video, canonical } = frontmatter;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate,
  author: { '@type': 'Person', name: author },
  ...(image ? { image } : {}),
};
const videoSchema = video
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: title,
      description,
      thumbnailUrl: [`https://i.ytimg.com/vi/${video}/maxresdefault.jpg`],
      uploadDate: pubDate,
      contentUrl: `https://www.youtube.com/watch?v=${video}`,
      embedUrl: `https://www.youtube-nocookie.com/embed/${video}`,
    }
  : null;
---

<BaseLayout title={`${title} - Markas Walet`} description={description} canonical={canonical} image={image} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {videoSchema && <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />}
  </Fragment>

  <main class="article-main">
    <a class="back" href="/article/">← Semua artikel</a>
    <h1>{title}</h1>
    <div class="meta">{author}{pubDate ? ` · ${pubDate}` : ''}</div>
    {image && <img class="hero" src={image} alt={title} loading="eager" />}
    <article>
      <slot />
      {video && (
        <figure class="video">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${video}`}
            title={title}
            loading="lazy"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen></iframe>
        </figure>
      )}
    </article>
  </main>

  <style>
    .article-main { max-width: var(--w); margin: 0 auto; padding: 28px 20px 8px; }
    .back { display: inline-block; margin-bottom: 14px; font-size: 0.9rem; text-decoration: none; }
    h1 { font-size: 2rem; line-height: 1.2; margin: 0.2em 0; }
    .meta { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5em; }
    .hero { width: 100%; border-radius: 10px; margin: 0 0 1.5em; }
    article :global(h2) { margin-top: 1.6em; font-size: 1.4rem; }
    article :global(h3) { margin-top: 1.3em; font-size: 1.15rem; }
    article :global(img) { border-radius: 8px; margin: 1em 0; }
    .video { position: relative; aspect-ratio: 16/9; margin: 2em 0; }
    .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 8px; }
  </style>
</BaseLayout>
