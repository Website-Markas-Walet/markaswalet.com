---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: string;
}
const { title, description = '', canonical, image = '', ogType = 'website' } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;

const products = [
  { label: 'Premium Birdnest Product', href: '/premium-birdnest-product/' },
  { label: 'Markaswalet Apps', href: '/markaswalet-apps/' },
  { label: 'Cultivation Technology', href: '/cultivation-technology/' },
  { label: 'Farming Products', href: '/farming-products/' },
  { label: 'Swiftlet House Construction', href: '/swiftlet-house-construction/' },
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}
    <link rel="icon" href="/wp-content/uploads/2023/04/cropped-logo-website-white-291x45.png" />
    <style is:global>
      :root { --w: 760px; --wide: 1080px; --ink: #18201c; --muted: #5d6b63; --line: #e7ebe8; --accent: #0a7d4b; --accent-dark: #075c37; --bg-soft: #f4f8f5; --gold: #f4b41a; }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; font: 17px/1.7 system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; color: var(--ink); }
      a { color: var(--accent); }
      img { max-width: 100%; height: auto; }
      .wrap { max-width: var(--wide); margin: 0 auto; padding: 0 20px; }
      /* header */
      .site-header { border-bottom: 1px solid var(--line); position: sticky; top: 0; background: #fff; z-index: 10; }
      .site-header .bar { display: flex; align-items: center; gap: 20px; padding: 12px 20px; max-width: var(--wide); margin: 0 auto; flex-wrap: wrap; }
      .site-header .logo img { height: 38px; display: block; }
      .site-nav { display: flex; align-items: center; gap: 26px; margin-left: auto; font-size: .95rem; }
      .site-nav > a, .site-nav .dd > .dd-t { color: var(--ink); background: none; border: 0; font: inherit; cursor: pointer; text-decoration: none; padding: 6px 0; white-space: nowrap; font-weight: 600; }
      .site-nav > a:hover, .site-nav .dd:hover > .dd-t { color: var(--accent); }
      .site-nav .dd { position: relative; }
      .site-nav .dd > .dd-t::after { content: ' ▾'; font-size: .8em; }
      .site-nav .dd-menu { position: absolute; top: 100%; right: 0; min-width: 230px; background: #fff; border: 1px solid var(--line); border-radius: 10px; padding: 8px; display: none; box-shadow: 0 12px 30px rgba(0,0,0,.12); }
      .site-nav .dd:hover .dd-menu, .site-nav .dd:focus-within .dd-menu { display: block; }
      .site-nav .dd-menu a { display: block; color: var(--ink); text-decoration: none; font-size: .9rem; padding: 9px 12px; border-radius: 7px; white-space: nowrap; }
      .site-nav .dd-menu a:hover { background: var(--bg-soft); color: var(--accent); }
      @media (max-width: 820px) {
        .site-nav { gap: 14px 18px; flex-wrap: wrap; margin: 8px 0 0; }
        .site-nav .dd-menu { position: static; display: block; border: 0; box-shadow: none; padding: 0 0 0 12px; min-width: 0; }
      }
      /* footer */
      .site-footer { background: var(--bg-soft); border-top: 1px solid var(--line); margin-top: 48px; }
      .site-footer .cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 24px; padding: 40px 20px; max-width: var(--wide); margin: 0 auto; }
      .site-footer h4 { margin: 0 0 10px; font-size: .95rem; }
      .site-footer ul { list-style: none; margin: 0; padding: 0; }
      .site-footer li { padding: 3px 0; }
      .site-footer a { color: var(--muted); text-decoration: none; font-size: .9rem; }
      .site-footer a:hover { color: var(--accent); }
      .site-footer .copy { text-align: center; padding: 16px; color: var(--muted); font-size: .85rem; border-top: 1px solid var(--line); }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a href="/" class="logo"><img src="/wp-content/uploads/2023/04/cropped-logo-website-white-291x45.png" alt="Markas Walet" width="291" height="45" /></a>
        <nav class="site-nav">
          <a href="/">Home</a>
          <div class="dd">
            <button class="dd-t" type="button" aria-haspopup="true">Our Product</button>
            <div class="dd-menu">
              {products.map((p) => <a href={p.href}>{p.label}</a>)}
            </div>
          </div>
          <a href="/article/">Article</a>
          <a href="/about-us/">About Us</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="cols">
        <div>
          <h4>Markas Walet</h4>
          <p style="color:var(--muted);font-size:.9rem;margin:0">Edukasi & produk budidaya sarang burung walet.</p>
        </div>
        <div>
          <h4>Produk</h4>
          <ul>
            <li><a href="/premium-birdnest-product/">Premium Birdnest</a></li>
            <li><a href="/markaswalet-apps/">Markaswalet Apps</a></li>
            <li><a href="/cultivation-technology/">Cultivation Technology</a></li>
            <li><a href="/swiftlet-house-construction/">Swiftlet House Construction</a></li>
          </ul>
        </div>
        <div>
          <h4>Jelajah</h4>
          <ul>
            <li><a href="/article/">Artikel</a></li>
            <li><a href="/about-us/">Tentang Kami</a></li>
          </ul>
        </div>
      </div>
      <div class="copy">© Markas Walet</div>
    </footer>
  </body>
</html>
