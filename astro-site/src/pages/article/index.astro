---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => a.data.title && !/^\d+$/.test(a.slug))
  .sort((a, b) => (b.data.pubDate || '').localeCompare(a.data.pubDate || ''));
---

<BaseLayout
  title="Artikel — Markas Walet"
  description="Kumpulan artikel seputar budidaya, teknologi, dan sarang burung walet."
>
  <main class="wrap list">
    <h1>Artikel <span>({articles.length})</span></h1>
    <div class="grid">
      {articles.map((a) => (
        <a class="card" href={`/article/${a.slug}/`}>
          {a.data.image && <img src={a.data.image} alt={a.data.title} loading="lazy" />}
          <div class="card-body">
            <h2>{a.data.title}</h2>
            {a.data.pubDate && <span class="date">{a.data.pubDate}</span>}
          </div>
        </a>
      ))}
    </div>
  </main>

  <style>
    .list { padding: 32px 20px; }
    .list h1 { font-size: 1.9rem; margin: 0 0 24px; }
    .list h1 span { color: var(--muted); font-weight: 400; font-size: 1.1rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 18px; }
    .card { display: block; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; background: #fff; transition: box-shadow .15s, transform .15s; }
    .card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.07); transform: translateY(-2px); }
    .card img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }
    .card-body { padding: 14px 16px; }
    .card h2 { margin: 0 0 6px; font-size: 1.02rem; line-height: 1.35; }
    .card .date { color: var(--muted); font-size: 0.82rem; }
  </style>
</BaseLayout>
