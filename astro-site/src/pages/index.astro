---
// Faithful homepage: the original hand-coded ".mw-content-wrap" design (hero,
// ecosystem diagram, sections) lifted out of the WordPress/Elementor shell.
// Same markup + same inline CSS + same assets => pixel-identical, but with
// none of the 40 stylesheets / 50 scripts / jQuery the export carried.
import bodyHtml from '../home/homepage-body.html?raw';
import customJs from '../home/homepage.js?raw';

const products = [
  { label: 'Premium Birdnest Product', href: '/premium-birdnest-product/' },
  { label: 'Markaswalet Apps', href: '/markaswalet-apps/' },
  { label: 'Cultivation Technology', href: '/cultivation-technology/' },
  { label: 'Farming Products', href: '/farming-products/' },
  { label: 'Swiftlet House Construction', href: '/swiftlet-house-construction/' },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Markas Walet',
  url: 'https://markaswalet.com',
  logo: 'https://markaswalet.com/wp-content/uploads/2023/04/cropped-logo-website-white-291x45.png',
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Markas Walet — Built from Community, Powered by Technology</title>
    <meta name="description" content="Indonesia's most traceable raw bird nest supply. Edukasi, teknologi IoT, dan produk untuk ekosistem budidaya sarang burung walet." />
    <link rel="canonical" href="https://markaswalet.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Markas Walet — Built from Community, Powered by Technology" />
    <meta property="og:image" content="/wp-content/uploads/2023/05/Asset-41.png" />
    <link rel="icon" href="/wp-content/uploads/2023/04/cropped-logo-website-white-291x45.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <style is:global>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: 'Poppins', system-ui, -apple-system, sans-serif; color: #18201c; }
      img { max-width: 100%; height: auto; }
      .hp-header { background: #0b241d; position: sticky; top: 0; z-index: 50; }
      .hp-bar { display: flex; align-items: center; gap: 18px; max-width: 1180px; margin: 0 auto; padding: 14px 20px; }
      .hp-bar .logo img { height: 44px; display: block; }
      .hp-nav { display: flex; align-items: center; gap: 28px; margin-left: auto; }
      .hp-nav > a, .hp-nav .dd > .dd-t { color: #eaf3ee; background: none; border: 0; font: inherit; cursor: pointer; text-decoration: none; font-size: 0.95rem; font-weight: 600; white-space: nowrap; padding: 6px 0; }
      .hp-nav > a:hover, .hp-nav .dd:hover > .dd-t, .hp-nav > a.active { color: #f4b41a; }
      .hp-nav .dd { position: relative; }
      .hp-nav .dd > .dd-t::after { content: ' ▾'; font-size: 0.8em; }
      .hp-nav .dd-menu { position: absolute; top: 100%; right: 0; min-width: 230px; background: #0b241d; border: 1px solid rgba(255,255,255,.12); border-radius: 10px; padding: 8px; display: none; box-shadow: 0 12px 30px rgba(0,0,0,.35); }
      .hp-nav .dd:hover .dd-menu, .hp-nav .dd:focus-within .dd-menu { display: block; }
      .hp-nav .dd-menu a { display: block; color: #eaf3ee; text-decoration: none; font-size: 0.9rem; padding: 9px 12px; border-radius: 7px; white-space: nowrap; }
      .hp-nav .dd-menu a:hover { background: rgba(244,180,26,.12); color: #f4b41a; }
      @media (max-width: 820px) {
        .hp-bar { flex-wrap: wrap; }
        .hp-nav { gap: 14px 18px; flex-wrap: wrap; margin: 8px 0 0; }
        .hp-nav .dd-menu { position: static; display: block; border: 0; box-shadow: none; padding: 0 0 0 12px; min-width: 0; background: none; }
      }
    </style>
  </head>
  <body>
    <header class="hp-header">
      <div class="hp-bar">
        <a href="/" class="logo"><img src="/wp-content/uploads/2023/04/cropped-logo-website-white-291x45.png" alt="Markas Walet" width="291" height="45" /></a>
        <nav class="hp-nav">
          <a href="/" class="active">Home</a>
          <div class="dd">
            <button class="dd-t" type="button" aria-haspopup="true">Our Product</button>
            <div class="dd-menu">
              {products.map((p) => <a href={p.href}>{p.label}</a>)}
            </div>
          </div>
          <a href="/article/">Article</a>
          <a href="/about-us/">About Us</a>
        </nav>
      </div>
    </header>

    <Fragment set:html={bodyHtml} />

    <script is:inline set:html={customJs} />
  </body>
</html>
